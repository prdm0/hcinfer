Package: hcinfer
Title: Heteroskedasticity-Consistent Inference for Linear Models
Version: 0.0.0.9000
Authors@R: c(
    person("Pedro Rafael D.", "Marinho", email = "pedro.rafael.marinho@gmail.com",
